<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.auctionfx.controller.AuctionDetailController">
    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label fx:id="descriptionLabel" wrapText="true"/>
    <Label fx:id="currentPriceLabel"/>
    <Label fx:id="endTimeLabel"/>
    <HBox spacing="10">
        <TextField fx:id="bidAmountField" promptText="Your bid"/>
        <Button text="Place Bid" onAction="#handlePlaceBid"/>
    </HBox>
    <Label fx:id="messageLabel" textFill="red"/>
    <Button text="Back to List" onAction="#handleBack"/>
</VBox>